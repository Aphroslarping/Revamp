-- ── AUTO RESPAWN ─────────────────────────────────────────────

local ReplicatedStorage = game:GetService("ReplicatedStorage")

local autoRespawnEnabled = false
local isRespawning = false      -- Prevents multiple loops

-- Attempt to respawn using remote first, then fallback to GUI button
local function attemptRespawnUntilAlive()
    if isRespawning then return end
    isRespawning = true

    -- Keep trying until the player is alive again
    while autoRespawnEnabled do
        -- Check if player is alive (character exists and humanoid health > 0)
        local char = LocalPlayer.Character
        if char then
            local humanoid = char:FindFirstChild("Humanoid")
            if humanoid and humanoid.Health > 0 then
                -- Player is alive, stop looping
                break
            end
        end

        -- Method 1: Try firing the remote (if it exists)
        local remoteSuccess = pcall(function()
            local remotes = ReplicatedStorage:FindFirstChild("Remotes")
            if remotes then
                local duels = remotes:FindFirstChild("Duels")
                if duels then
                    local respawnRemote = duels:FindFirstChild("RespawnNow")
                    if respawnRemote then
                        respawnRemote:FireServer()
                        return true
                    end
                end
            end
            return false
        end)

        -- If remote worked, give the game a moment to respawn the player
        if remoteSuccess then
            task.wait(0.5)
            -- Continue loop; will break when alive
        end

        -- Method 2: Search for and click a respawn button in PlayerGui
        local gui = LocalPlayer:FindFirstChild("PlayerGui")
        if gui then
            for _, obj in ipairs(gui:GetDescendants()) do
                if obj:IsA("TextButton") or obj:IsA("ImageButton") then
                    if obj.Name:lower():find("respawn") or 
                       (obj.Text and obj.Text:lower():find("respawn")) then
                        -- Click the button (fire MouseButton1Click if needed)
                        obj:Click()
                        -- Wait a bit after clicking
                        task.wait(0.5)
                        break
                    end
                end
            end
        end

        -- Wait a bit before next attempt
        task.wait(0.5)
    end

    isRespawning = false
end

-- Hook into character death
local function onCharacterAdded(char)
    local humanoid = char:WaitForChild("Humanoid")
    humanoid.Died:Connect(function()
        if autoRespawnEnabled then
            -- Small delay to let death animation/UI appear
            task.wait(0.3)
            attemptRespawnUntilAlive()
        end
    end)
end

