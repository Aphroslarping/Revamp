-- ── AUTO BEGGAR WRAP ─────────────────────────────────────────

local ReplicatedStorage_Beg = game:GetService("ReplicatedStorage")
local RunService_Beg = game:GetService("RunService")

local BEG_DELAY = 0.3
local MAX_RETRIES = 3
local AUTO_RESTART = true

local beggarActive = false
local beggarThread = nil
local remoteCache = nil
local connectionAttempts = 0
local isShuttingDown = false

local function findBegRemote()
    if remoteCache and remoteCache.Parent then
        return remoteCache
    end

    remoteCache = nil

    local success, remote = pcall(function()
        return ReplicatedStorage_Beg
            :WaitForChild("Remotes", 5)
            :WaitForChild("Misc", 5)
            :WaitForChild("DialogAction", 5)
    end)

    if success and remote then
        remoteCache = remote
        return remote
    end

    for _, obj in ipairs(ReplicatedStorage_Beg:GetDescendants()) do
        if obj:IsA("RemoteEvent") or obj:IsA("RemoteFunction") then
            local name = obj.Name:lower()
            if name:find("dialog") or name:find("action") or name:find("beg") then
                remoteCache = obj
                return obj
            end
        end
    end

    local commonPaths = {
        {ReplicatedStorage_Beg, "Remotes", "Misc", "DialogAction"},
        {ReplicatedStorage_Beg, "Remotes", "DialogAction"},
        {ReplicatedStorage_Beg, "Misc", "DialogAction"},
        {ReplicatedStorage_Beg, "DialogAction"},
        {ReplicatedStorage_Beg, "Remotes", "Beg"},
        {ReplicatedStorage_Beg, "Beg"},
    }

    for _, path in ipairs(commonPaths) do
        local current = ReplicatedStorage_Beg
        local found = true

        for i = 2, #path do
            current = current:FindFirstChild(path[i])
            if not current then
                found = false
                break
            end
        end

        if found and (current:IsA("RemoteEvent") or current:IsA("RemoteFunction")) then
            remoteCache = current
            return current
        end
    end

    return nil
end

local function fireBegRemote(remote)
    if not remote then return false end

    local argumentPatterns = {
        {"beg"},
        {["command"] = "beg"},
        {["action"] = "beg"},
        {["type"] = "beg"},
        {["msg"] = "beg"},
        {},
        {"beg", LocalPlayer},
        {LocalPlayer, "beg"},
    }

    for i, args in ipairs(argumentPatterns) do
        local success = pcall(function()
            if type(args) == "table" and next(args) == nil then
                remote:FireServer()
            else
                remote:FireServer(unpack(args))
            end
        end)

        if success then
            if i <= 3 then
                return true
            end
            task.wait(0.05)
        end
    end

    return true
end

local function ensureRemoteAlive()
    local remote = findBegRemote()
    if not remote then
        connectionAttempts = connectionAttempts + 1

        if connectionAttempts >= MAX_RETRIES then
            remoteCache = nil
            connectionAttempts = 0
            task.wait(1)
            remote = findBegRemote()
        end
    else
        connectionAttempts = 0
    end

    return remote
end

local function beggarLoop()
    task.wait(2)

    while beggarActive and not isShuttingDown do
        local remote = ensureRemoteAlive()

        if remote then
            local success = pcall(function()
                fireBegRemote(remote)
            end)

            if not success then
                remoteCache = nil
                task.wait(0.5)
            end
        else
            task.wait(1)
        end

        if remote then
            task.wait(BEG_DELAY)
        else
            task.wait(1)
        end

        RunService_Beg.Heartbeat:Wait()
    end
end

local stopBeggar
local startBeggar

startBeggar = function()
    if beggarActive then return end

    beggarActive = true
    isShuttingDown = false
    connectionAttempts = 0

    beggarThread = task.spawn(function()
        local success, err = pcall(beggarLoop)

        if not success and beggarActive and AUTO_RESTART then
            task.wait(1)
            if beggarActive then
                startBeggar()
            end
        end
    end)
end

stopBeggar = function()
    beggarActive = false
    isShuttingDown = true

    if beggarThread then
        pcall(function()
            task.cancel(beggarThread)
        end)
        beggarThread = nil
    end

    remoteCache = nil
    connectionAttempts = 0
end

LocalPlayer.CharacterAdded:Connect(function()
    if beggarActive then
        task.wait(1.5)
        remoteCache = nil
    end
end)

pcall(function()
    game:BindToClose(function()
        isShuttingDown = true
        beggarActive = false
    end)
end)

workspace.ChildAdded:Connect(function()
    if beggarActive then
        remoteCache = nil
    end
end)

task.spawn(function()
    while true do
        task.wait(30)

        if beggarActive then
            if not beggarThread then
                stopBeggar()
                task.wait(0.5)
                startBeggar()
            end
        end
    end
end)

FeaturesSection:AddToggle("Auto Beggar Wrap", false, function(state)
    if state then
        startBeggar()
    else
        stopBeggar()
    end
end)

