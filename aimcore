                    myRoot = orbitGetMyRoot()
                    if not myRoot then task.wait(0.1); continue end
                    print("🔄 Respawned — resuming orbit!")
                end

                orbitSwapTimer += TELEPORT_SPEED

                local needsSwap = false
                local swapReason = ""

                if SWAP_ON_DEATH and orbitCurrentTarget then
                    if not orbitIsTargetAlive(orbitCurrentTarget) then
                        needsSwap  = true
                        swapReason = "💀 Target died"
                    end
                end

                if orbitSwapTimer >= SWAP_INTERVAL then
                    needsSwap  = true
                    swapReason = "🔀 Auto-swap timer"
                    orbitSwapTimer = 0
                end

                if not orbitCurrentTarget and orbitCurrentTargetName ~= "SELF" then
                    needsSwap  = true
                    swapReason = "🎯 No target"
                end

                if needsSwap then
                    local oldName = orbitCurrentTargetName
                    orbitPickNextTarget()
                    if orbitCurrentTargetName ~= oldName then
                        if orbitCurrentTargetName == "SELF" then
                            print(swapReason .. " → No players found, orbiting self")
                        else
                            print(swapReason .. " → Now orbiting: " .. orbitCurrentTargetName)
                        end
                    end
                    orbitSwapTimer = 0
                end

                local ePos, eRoot
                if orbitCurrentTarget and orbitCurrentTarget.Parent then
                    ePos  = orbitCurrentTarget.Position
                    eRoot = orbitCurrentTarget
                else
                    ePos  = myRoot.Position + Vector3.new(0, 10, 0)
                    eRoot = nil
                end

                local newPos, usedMode = orbitGetUltimatePosition(ePos, eRoot)
                pcall(function()
                    myRoot.CFrame = CFrame.new(newPos)
                end)

                orbitTeleportCount += 1
                if orbitTeleportCount % 200 == 0 then
                    local targetDisplay = orbitCurrentTargetName ~= "" and orbitCurrentTargetName or "SELF"
                    print("⚡ Mode: " .. usedMode:upper() .. " | Target: " .. targetDisplay .. " | Teleports: " .. orbitTeleportCount)
                end

                task.wait(TELEPORT_SPEED)
            end

            print("🛑 ORBIT AURA — DISABLED")
        end)
    end
end)

-- ── FFA ORBIT ────────────────────────────────────────────────

local ffaOrbitEnabled = false

-- FFA CONFIG (renamed from CONFIG to avoid collision with GUI CONFIG)
local FFA_CONFIG = {
    VoidPosition            = Vector3.new(0, -1000, 0),
    VoidOffset              = Vector3.new(0, 5, 0),
    OrbitSpeed              = 300,
    MinRadius               = 3,
    MaxRadius               = 5,
    HeightOffset            = 100,
    VerticalOscillation     = 15,
    VerticalOscillationSpeed = 6,
    PredictionTime          = 0.15,
    Smoothness              = 0.08,
    PreferClosest           = true,
    SetAimTargets           = true,
}

-- State variables (prefixed ffa to avoid any collisions)
local ffaChar             = nil
local ffaHRP              = nil
local ffaOrbitAngle       = 0
local ffaLastCameraCFrame = nil
local ffaTimeAccum        = 0
local ffaRenderConn       = nil
local ffaRespawnConn      = nil

local function ffaGetCharParts()
    local char = LocalPlayer.Character
    if not char then return nil, nil end
    return char, char:FindFirstChild("HumanoidRootPart")
end

local function ffaIsEnemyAlive(enemyChar)
    local hum = enemyChar:FindFirstChildOfClass("Humanoid")
    local hrp = enemyChar:FindFirstChild("HumanoidRootPart")
    return hum and hrp and hum.Health > 0
end

local function ffaGetBestEnemy()
    if not ffaHRP then return nil end
    local bestEnemy = nil
    local bestDist  = math.huge
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and plr.Character then
            local enemyChar = plr.Character
            if ffaIsEnemyAlive(enemyChar) then
                local hrp = enemyChar:FindFirstChild("HumanoidRootPart")
                if hrp then
                    local dist = (ffaHRP.Position - hrp.Position).Magnitude
                    if dist < bestDist then
                        bestDist  = dist
                        bestEnemy = enemyChar
                    end
                end
            end
        end
    end
    return bestEnemy
end

local function ffaHoldInVoid()
    if ffaHRP then
        pcall(function()
            ffaHRP.CFrame = CFrame.new(FFA_CONFIG.VoidPosition + FFA_CONFIG.VoidOffset)
            ffaHRP.AssemblyLinearVelocity  = Vector3.zero
            ffaHRP.AssemblyAngularVelocity = Vector3.zero
        end)
    end
end

local function ffaUpdateCamera(enemy, dt)
    if not enemy or not ffaHRP then return end
    local head = enemy:FindFirstChild("Head")
    local ehrp = enemy:FindFirstChild("HumanoidRootPart")
    if not head or not ehrp then return end

    local Camera = workspace.CurrentCamera

    ffaOrbitAngle = ffaOrbitAngle + FFA_CONFIG.OrbitSpeed * dt
    ffaTimeAccum  = ffaTimeAccum  + dt

    -- Predict enemy position
    local velocity     = ehrp.AssemblyLinearVelocity
    local predictedPos = head.Position + velocity * FFA_CONFIG.PredictionTime

    -- Dynamic radius clamped between min and max
    local dist   = (ffaHRP.Position - ehrp.Position).Magnitude
    local radius = math.clamp(dist * 1.2, FFA_CONFIG.MinRadius, FFA_CONFIG.MaxRadius)

    -- Vertical oscillation
    local verticalOffset = FFA_CONFIG.HeightOffset
    if FFA_CONFIG.VerticalOscillation > 0 then
        verticalOffset = verticalOffset
            + math.sin(ffaTimeAccum * FFA_CONFIG.VerticalOscillationSpeed)
            * FFA_CONFIG.VerticalOscillation
    end

    -- Orbit camera position
    local rad       = math.rad(ffaOrbitAngle)
    local orbitOff  = Vector3.new(math.cos(rad) * radius, verticalOffset, math.sin(rad) * radius)
    local camPos    = predictedPos + orbitOff

    -- Smoothly lerp camera CFrame
    local targetCF      = CFrame.lookAt(camPos, predictedPos)
    ffaLastCameraCFrame = ffaLastCameraCFrame:Lerp(targetCF, FFA_CONFIG.Smoothness)
    Camera.CFrame       = ffaLastCameraCFrame

    -- External aim hooks
    if FFA_CONFIG.SetAimTargets then
        if _G.SilentAim then _G.SilentAim.Target = predictedPos end
        if _G.RageBot   then _G.RageBot.Target   = predictedPos end
    end
end

local function ffaStop()
    ffaOrbitEnabled = false

    -- Disconnect RenderStepped
    if ffaRenderConn then
        ffaRenderConn:Disconnect()
        ffaRenderConn = nil
    end

    -- Disconnect respawn listener
    if ffaRespawnConn then
        ffaRespawnConn:Disconnect()
        ffaRespawnConn = nil
    end

    -- Restore camera to default scriptable type
    local Camera = workspace.CurrentCamera
    Camera.CameraType = Enum.CameraType.Custom

    print("🛑 FFA ORBIT — DISABLED")
end

local function ffaStart()
    -- Initialise state
    ffaChar, ffaHRP   = ffaGetCharParts()
    ffaOrbitAngle     = 0
    ffaTimeAccum      = 0
    ffaLastCameraCFrame = workspace.CurrentCamera.CFrame

    -- Lock camera so our CFrame writes take effect
    workspace.CurrentCamera.CameraType = Enum.CameraType.Scriptable

    print("🚀 FFA ORBIT — ENABLED")
    print("⚡ Void hold + closest-enemy orbit camera active")

    -- Respawn handler
    ffaRespawnConn = LocalPlayer.CharacterAdded:Connect(function(newChar)
        repeat task.wait() until newChar and newChar:FindFirstChild("HumanoidRootPart")
        ffaChar = newChar
        ffaHRP  = newChar.HumanoidRootPart
        -- Re-lock camera after respawn (Roblox resets it)
        workspace.CurrentCamera.CameraType = Enum.CameraType.Scriptable
        print("🔄 FFA ORBIT — Respawned, resuming")
    end)

    -- Main loop via RenderStepped
    ffaRenderConn = RunService.RenderStepped:Connect(function(dt)
        -- Re-acquire parts if lost
        if not ffaHRP or not ffaChar then
            ffaChar, ffaHRP = ffaGetCharParts()
        end

        if ffaHRP then
            ffaHoldInVoid()
            local enemy = ffaGetBestEnemy()
            if enemy then
                ffaUpdateCamera(enemy, dt)
            end
        end
    end)
end

CombatSection:AddToggle("FFA Orbit", false, function(state)
    if state then
        ffaOrbitEnabled = true
        ffaStart()
    else
        ffaStop()
    end
end)

