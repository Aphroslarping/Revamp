-- ── ORBIT AURA SCRIPT ────────────────────────────────────────

local orbitAuraEnabled = false

-- Orbit Aura Script - ULTIMATE TRI-MODE + MULTI-TARGET
-- Orbits real Roblox player characters only
-- Swaps targets when: current target dies | timer expires | new target found
-- NEVER STOPS - Even through rounds

local ABOVE_HEIGHT      = 25
local BEHIND_DISTANCE   = 20
local FRONT_DISTANCE    = 20
local ORBIT_RADIUS      = 9
local TELEPORT_SPEED    = 0.02

local SWAP_INTERVAL     = 10.0
local SWAP_ON_DEATH     = true

local orbitTeleportCount     = 0
local orbitLastMode          = "above"
local orbitModeChangeCounter = 0

local orbitCurrentTarget     = nil
local orbitCurrentTargetName = ""
local orbitSwapTimer         = 0
local orbitTargetIndex       = 1

local function orbitGetMyRoot()
    local char = Players.LocalPlayer.Character
    return char and char:FindFirstChild("HumanoidRootPart")
end

local function orbitIsTargetAlive(root)
    if not root then return false end
    if not root.Parent then return false end
    local humanoid = root.Parent:FindFirstChild("Humanoid")
    if not humanoid or humanoid.Health <= 0 then return false end
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= Players.LocalPlayer and p.Character == root.Parent then
            return true
        end
    end
    return false
end

local function orbitGetAlivePlayers()
    local list = {}
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= Players.LocalPlayer and p.Character then
            local root     = p.Character:FindFirstChild("HumanoidRootPart")
            local humanoid = p.Character:FindFirstChild("Humanoid")
            if root and humanoid and humanoid.Health > 0 then
                table.insert(list, { root = root, name = p.Name })
            end
        end
    end
    return list
end

local function orbitGetAllPlayerRoots()
    local list = {}
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= Players.LocalPlayer and p.Character then
            local root = p.Character:FindFirstChild("HumanoidRootPart")
            if root then
                table.insert(list, { root = root, name = p.Name })
            end
        end
    end
    return list
end

local function orbitPickNextTarget()
    local alive = orbitGetAlivePlayers()
    if #alive == 1 then
        orbitCurrentTarget     = alive[1].root
        orbitCurrentTargetName = alive[1].name
        return
    end
    if #alive > 1 then
        local startIdx = 1
        for i, entry in ipairs(alive) do
            if entry.root == orbitCurrentTarget then
                startIdx = (i % #alive) + 1
                break
            end
        end
        orbitCurrentTarget     = alive[startIdx].root
        orbitCurrentTargetName = alive[startIdx].name
        return
    end
    local all = orbitGetAllPlayerRoots()
    if #all > 0 then
        orbitTargetIndex = (orbitTargetIndex % #all) + 1
        local pick = all[orbitTargetIndex] or all[1]
        orbitCurrentTarget     = pick.root
        orbitCurrentTargetName = pick.name
        return
    end
    orbitCurrentTarget     = nil
    orbitCurrentTargetName = "SELF"
end

local function orbitGetLookVector(rootPart)
    if rootPart and typeof(rootPart) == "Instance" and rootPart:IsA("BasePart") then
        return rootPart.CFrame.LookVector
    end
    return Vector3.new(0, 0, -1)
end

local function orbitGetAbovePosition(ePos, eRoot)
    local pattern = math.random(6)
    local x, z
    if pattern == 1 then
        x = (math.random() - 0.5) * ORBIT_RADIUS * 2
        z = (math.random() - 0.5) * ORBIT_RADIUS * 0.5
    elseif pattern == 2 then
        x = (math.random() - 0.5) * ORBIT_RADIUS * 0.5
        z = (math.random() - 0.5) * ORBIT_RADIUS * 2
    elseif pattern == 3 then
        local a = math.random() * 2 * math.pi
        x = math.cos(a) * ORBIT_RADIUS
        z = math.sin(a) * ORBIT_RADIUS
    elseif pattern == 4 then
        if math.random() < 0.5 then
            x = (math.random() - 0.5) * ORBIT_RADIUS * 2; z = 0
        else
            x = 0; z = (math.random() - 0.5) * ORBIT_RADIUS * 2
        end
    elseif pattern == 5 then
        x = (math.random() - 0.5) * ORBIT_RADIUS * 1.5
        z = (math.random() - 0.5) * ORBIT_RADIUS * 1.5
    else
        x = (math.random() - 0.5) * ORBIT_RADIUS * 2.5
        z = (math.random() - 0.5) * ORBIT_RADIUS * 2.5
    end
    x = x + (math.random() - 0.5) * 2
    z = z + (math.random() - 0.5) * 2
    return Vector3.new(
        ePos.X + x,
        ePos.Y + ABOVE_HEIGHT + (math.random() - 0.5) * 2,
        ePos.Z + z
    )
end

local function orbitGetSidedPosition(ePos, eRoot, distance)
    local look  = orbitGetLookVector(eRoot)
    local right = Vector3.new(look.Z, 0, -look.X)
    local rMag  = right.Magnitude
    right = rMag > 0.001 and right / rMag or Vector3.new(1, 0, 0)
    local pattern = math.random(5)
    local side = 0
    if pattern == 1 then
        side = -ORBIT_RADIUS * (0.5 + math.random() * 0.5)
    elseif pattern == 2 then
        side =  ORBIT_RADIUS * (0.5 + math.random() * 0.5)
    elseif pattern == 3 then
        side = -ORBIT_RADIUS * (0.2 + math.random() * 0.3)
    elseif pattern == 4 then
        side =  ORBIT_RADIUS * (0.2 + math.random() * 0.3)
    else
        side = (math.random() - 0.5) * ORBIT_RADIUS * 3
    end
    return Vector3.new(
        ePos.X + look.X * distance + right.X * side,
        ePos.Y + 2 + (math.random() - 0.5) * 3,
        ePos.Z + look.Z * distance + right.Z * side
    )
end

local function orbitGetUltimatePosition(ePos, eRoot)
    local mode
    if math.random() < 0.4 or orbitModeChangeCounter > 5 then
        local pool = {}
        for _, m in ipairs({"above", "behind", "front"}) do
            if m ~= orbitLastMode then table.insert(pool, m) end
        end
        if #pool == 0 then pool = {"above", "behind", "front"} end
        mode = pool[math.random(#pool)]
        orbitLastMode = mode
        orbitModeChangeCounter = 0
    else
        mode = orbitLastMode
        orbitModeChangeCounter += 1
    end
    if math.random() < 0.15 then
        mode = ({"above", "behind", "front"})[math.random(3)]
    end
    local pos
    if mode == "above" then
        pos = orbitGetAbovePosition(ePos, eRoot)
    elseif mode == "behind" then
        pos = orbitGetSidedPosition(ePos, eRoot, -BEHIND_DISTANCE)
    else
        pos = orbitGetSidedPosition(ePos, eRoot, FRONT_DISTANCE)
    end
    return pos, mode
end

-- ── ORBIT AURA TOGGLE ────────────────────────────────────────
CombatSection:AddToggle("Orbit Aura", false, function(state)
    orbitAuraEnabled = state

    if state then
        -- Reset state on enable
        orbitTeleportCount     = 0
        orbitLastMode          = "above"
        orbitModeChangeCounter = 0
        orbitCurrentTarget     = nil
        orbitCurrentTargetName = ""
        orbitSwapTimer         = 0
