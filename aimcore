        -- ─────────────────────────────────────────────────────
        -- ELEMENT: TOGGLE
        -- ─────────────────────────────────────────────────────
        function section:AddToggle(text, default, callback)
            local el     = {}
            local state  = default or false
            callback     = callback or function() end

            local Row = Instance.new("TextButton")
            Row.Size             = UDim2.new(1, 0, 0, 36)
            Row.BackgroundColor3 = CONFIG.Surface
            Row.Text             = ""
            Row.BorderSizePixel  = 0
            Row.AutoButtonColor  = false
            Row.ZIndex           = 12
            Row.Parent           = Scroll
            addCorner(Row, 8)
            addStroke(Row, CONFIG.Border, 1)

            local RowLabel = Instance.new("TextLabel")
            RowLabel.Size              = UDim2.new(1, -60, 1, 0)
            RowLabel.Position          = UDim2.new(0, 12, 0, 0)
            RowLabel.BackgroundTransparency = 1
            RowLabel.Text              = text
            RowLabel.Font              = Enum.Font.Gotham
            RowLabel.TextSize          = 13
            RowLabel.TextColor3        = CONFIG.Text
            RowLabel.TextXAlignment    = Enum.TextXAlignment.Left
            RowLabel.ZIndex            = 13
            RowLabel.Parent            = Row

            -- Toggle track
            local Track = Instance.new("Frame")
            Track.Size             = UDim2.new(0, 36, 0, 20)
            Track.Position         = UDim2.new(1, -46, 0.5, -10)
            Track.BackgroundColor3 = state and CONFIG.ToggleOn or CONFIG.ToggleOff
            Track.BorderSizePixel  = 0
            Track.ZIndex           = 13
            Track.Parent           = Row
            addCorner(Track, 10)

            -- Toggle knob
            local Knob = Instance.new("Frame")
            Knob.Size             = UDim2.new(0, 14, 0, 14)
            Knob.Position         = UDim2.new(0, state and 19 or 3, 0.5, -7)
            Knob.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
            Knob.BorderSizePixel  = 0
            Knob.ZIndex           = 14
            Knob.Parent           = Track
            addCorner(Knob, 7)

            local function setToggle(val, silent)
                state = val
                tween(Track, {BackgroundColor3 = state and CONFIG.ToggleOn or CONFIG.ToggleOff}, 0.18)
                tween(Knob,  {Position = UDim2.new(0, state and 19 or 3, 0.5, -7)}, 0.18)
                if not silent then pcall(callback, state) end
            end

            Row.MouseButton1Click:Connect(function()
                setToggle(not state)
            end)
            Row.MouseEnter:Connect(function()
                tween(Row, {BackgroundColor3 = CONFIG.SurfaceAlt}, 0.12)
            end)
            Row.MouseLeave:Connect(function()
                tween(Row, {BackgroundColor3 = CONFIG.Surface}, 0.12)
            end)

            setToggle(state, true)

            function el:Set(val) setToggle(val, true) end
            function el:Get() return state end
            return el
        end

        -- ─────────────────────────────────────────────────────
        -- ELEMENT: SLIDER
        -- ─────────────────────────────────────────────────────
        function section:AddSlider(text, min, max, default, callback)
            local el    = {}
            min         = min     or 0
            max         = max     or 100
            local value = math.clamp(default or min, min, max)
            callback    = callback or function() end

            local Container = Instance.new("Frame")
            Container.Size             = UDim2.new(1, 0, 0, 50)
            Container.BackgroundColor3 = CONFIG.Surface
            Container.BorderSizePixel  = 0
            Container.ZIndex           = 12
