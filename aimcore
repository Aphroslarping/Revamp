local VirtualUser = game:GetService("VirtualUser")
local VirtualInputManager = game:GetService("VirtualInputManager")

local antiAFKEnabled = false
local antiAFKThread = nil

-- Mobile-optimized anti-AFK
local function mobileAntiAFK()
    while antiAFKEnabled do
        pcall(function()
            -- Method 1: VirtualUser (works on mobile)
            VirtualUser:CaptureController()
            VirtualUser:ClickButton1(Vector2.new())
            
            task.wait(0.5)
            
            -- Method 2: Jump if alive
            local char = LocalPlayer.Character
            if char and char:FindFirstChild("Humanoid") then
                char.Humanoid.Jump = true
                task.wait(0.2)
                char.Humanoid.Jump = false
            end
            
            task.wait(0.5)
            
            -- Method 3: Touch screen simulation
            local viewportSize = workspace.CurrentCamera.ViewportSize
            VirtualInputManager:SendTouchEvent(true, Vector2.new(viewportSize.X/2, viewportSize.Y/2), 0, game)
            task.wait(0.1)
            VirtualInputManager:SendTouchEvent(false, Vector2.new(viewportSize.X/2, viewportSize.Y/2), 0, game)
        end)
        
        -- Wait 60 seconds between full cycles
        task.wait(60)
    end
end

