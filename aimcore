-- ── TAB CREATION ──────────────────────────────────────────────
function Library:CreateTab(name, icon)
    local tab = {}

    -- Tab button
    local TabBtn = Instance.new("TextButton")
    TabBtn.Name              = name
    TabBtn.Size              = UDim2.new(1, 0, 0, 36)
    TabBtn.BackgroundColor3  = CONFIG.SurfaceAlt
    TabBtn.BackgroundTransparency = 1
    TabBtn.Text              = (icon and (icon .. "  ") or "") .. name
    TabBtn.Font              = Enum.Font.Gotham
    TabBtn.TextSize          = 12
    TabBtn.TextColor3        = CONFIG.TextDim
    TabBtn.TextXAlignment    = Enum.TextXAlignment.Left
    TabBtn.BorderSizePixel   = 0
    TabBtn.LayoutOrder       = #Tabs + 1
    TabBtn.ZIndex            = 12
    TabBtn.Parent            = TabBar
    addCorner(TabBtn, 7)

    local TabBtnPad = Instance.new("UIPadding")
    TabBtnPad.PaddingLeft = UDim.new(0, 10)
    TabBtnPad.Parent      = TabBtn

    -- Active indicator bar
    local ActiveBar = Instance.new("Frame")
    ActiveBar.Size             = UDim2.new(0, 3, 0.5, 0)
    ActiveBar.Position         = UDim2.new(0, -1, 0.25, 0)
    ActiveBar.BackgroundColor3 = CONFIG.Accent
    ActiveBar.BorderSizePixel  = 0
    ActiveBar.Visible          = false
    ActiveBar.ZIndex           = 13
    ActiveBar.Parent           = TabBtn
    addCorner(ActiveBar, 3)

    -- ScrollingFrame for this tab's content
    local Scroll = Instance.new("ScrollingFrame")
    Scroll.Name                   = name .. "Scroll"
    Scroll.Size                   = UDim2.new(1, 0, 1, 0)
    Scroll.BackgroundTransparency = 1
    Scroll.BorderSizePixel        = 0
    Scroll.ScrollBarThickness     = 3
    Scroll.ScrollBarImageColor3   = CONFIG.Accent
    Scroll.CanvasSize             = UDim2.new(0, 0, 0, 0)
    Scroll.AutomaticCanvasSize    = Enum.AutomaticSize.Y
    Scroll.Visible                = false
    Scroll.ZIndex                 = 11
    Scroll.Parent                 = ContentArea

    local ScrollPad = Instance.new("UIPadding")
    ScrollPad.PaddingTop    = UDim.new(0, 10)
    ScrollPad.PaddingBottom = UDim.new(0, 10)
    ScrollPad.PaddingLeft   = UDim.new(0, 12)
    ScrollPad.PaddingRight  = UDim.new(0, 12)
    ScrollPad.Parent        = Scroll

    local ScrollLayout = Instance.new("UIListLayout")
    ScrollLayout.SortOrder    = Enum.SortOrder.LayoutOrder
    ScrollLayout.Padding      = UDim.new(0, 7)
    ScrollLayout.Parent       = Scroll

    -- Store references
    tab._btn       = TabBtn
    tab._scroll    = Scroll
    tab._bar       = ActiveBar
    tab._orderIdx  = #Tabs + 1

    -- Tab click to switch
    TabBtn.MouseButton1Click:Connect(function()
        Library:_SelectTab(tab)
    end)

    TabBtn.MouseEnter:Connect(function()
        if ActiveTab ~= tab then
            tween(TabBtn, {BackgroundTransparency = 0.7, TextColor3 = CONFIG.Text}, 0.12)
        end
    end)
    TabBtn.MouseLeave:Connect(function()
        if ActiveTab ~= tab then
            tween(TabBtn, {BackgroundTransparency = 1, TextColor3 = CONFIG.TextDim}, 0.12)
        end
    end)

    table.insert(Tabs, tab)

    -- Auto-select first tab
    if #Tabs == 1 then
        Library:_SelectTab(tab)
    end

